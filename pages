<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>2026年山海央小青</title>
    <style>
        /* ========== 样式（与之前一致，略作精简） ========== */
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', 'PingFang SC', Roboto, sans-serif;
            background: #f5f7fb;
            color: #1e293b;
            padding: 20px 12px;
            min-height: 100vh;
        }
        .container { max-width: 1440px; margin: 0 auto; }
        .header {
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 16px 0 24px;
            border-bottom: 1px solid #e9edf4;
            margin-bottom: 30px;
        }
        .header .avatar {
            width: 64px; height: 64px;
            border-radius: 50%;
            background: linear-gradient(135deg, #667eea, #764ba2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            color: #fff;
            flex-shrink: 0;
        }
        .header .title-group h1 {
            font-size: 28px;
            font-weight: 700;
            color: #0f172a;
        }
        .header .title-group .subtitle {
            font-size: 14px;
            color: #64748b;
        }
        .header .title-group .divider {
            width: 50px; height: 3px;
            background: linear-gradient(90deg, #667eea, #764ba2);
            border-radius: 4px;
            margin-top: 4px;
        }
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 24px;
        }
        .card {
            background: #fff;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 8px 24px rgba(0,0,0,0.05);
            transition: transform 0.2s;
        }
        .card:hover { transform: translateY(-4px); }
        .video-wrapper {
            position: relative;
            background: #0f172a;
            aspect-ratio: 16 / 9;
            overflow: hidden;
        }
        /* ===== ★ 微信播放核心修复 ===== */
        .video-wrapper video {
            display: block;
            width: 100%;
            height: 100%;
            object-fit: cover;
            background: #0f172a;
            /* 强制GPU加速，避免悬停模糊 */
            transform: translateZ(0);
            backface-visibility: hidden;
            will-change: transform;
        }
        .video-badge {
            position: absolute;
            top: 12px; left: 12px;
            background: rgba(0,0,0,0.6);
            color: #fff;
            font-size: 12px;
            font-weight: 600;
            padding: 2px 12px;
            border-radius: 20px;
            pointer-events: none;
        }
        .card-body {
            padding: 16px 18px 20px;
        }
        .card-body .card-title {
            font-size: 17px;
            font-weight: 600;
            color: #0f172a;
        }
        .card-body .card-title .num { color: #94a3b8; font-weight: 400; }
        .card-body .card-desc {
            font-size: 14px;
            line-height: 1.6;
            color: #475569;
            margin: 4px 0 10px;
        }
        .card-body .card-tag {
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
        }
        .card-body .card-tag span {
            background: #f1f5f9;
            color: #475569;
            font-size: 11px;
            padding: 2px 12px;
            border-radius: 20px;
        }
        .footer {
            text-align: center;
            padding: 30px 16px 16px;
            color: #94a3b8;
            font-size: 13px;
            border-top: 1px solid #e9edf4;
            margin-top: 30px;
        }
        @media (max-width: 480px) {
            .header .title-group h1 { font-size: 22px; }
            .grid { gap: 16px; }
        }
    </style>
</head>
<body>
